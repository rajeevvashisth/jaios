# --- Database ---
POSTGRES_USER=jaios
POSTGRES_PASSWORD=jaios
POSTGRES_DB=jaios
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://jaios:jaios@localhost:5432/jaios

# --- LLM providers (set at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
#
# OLLAMA_BASE_URL depends on how the backend runs relative to Ollama:
#   - Backend via `docker compose`, Ollama already running natively on your
#     Mac (brew/ollama.ai install)  -> http://host.docker.internal:11434
#   - Backend via `docker compose`, using the bundled `ollama` service
#     (`docker compose --profile local-models up`)  -> http://ollama:11434
#   - Backend running natively (`make backend-dev`, no Docker)  -> http://localhost:11434
# `localhost` here refers to whatever ran this process — inside the backend
# container that's the container itself, not your Mac or the ollama
# service, which is the single most common way this setting goes wrong.
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-5

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Tool sandbox ---
WORKSPACE_ROOT=./workspace

# --- Coding worker (Developer agent) ---
# claude_code requires the `claude` CLI on PATH; openhands requires `openhands`.
# Missing binaries degrade to a failed tool result, not a crash.
CODING_WORKER_BACKEND=claude_code

# --- Governance ---
# Comma-separated action types that always require human approval regardless of agent config
GLOBAL_APPROVAL_REQUIRED_ACTIONS=deploy,finance_payment,legal_signature

# --- Integrations (optional) ---
# Operations agent posts notifications here if set; unset = tool no-ops gracefully.
SLACK_WEBHOOK_URL=

# --- Auth ---
# Generate a real secret before any non-local deployment, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=insecure-dev-secret-change-me-before-any-real-deployment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- BYOK secret encryption ---
# Required before any workspace stores its own AI provider credentials
# (AI Settings -> Providers). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing/rotating this key makes previously-stored provider keys
# undecryptable — see backend/app/core/secrets.py for the full limitation.
SECRET_ENCRYPTION_KEY=
